# Copy this file to .env before starting:
# cp .env.example .env

WEBUI_NAME=Local RAG

# Generate one with: openssl rand -hex 32
WEBUI_SECRET_KEY=change-me-generate-a-long-random-string

# Path to your Open WebUI AppImage.
# Example: /home/abhinav/Downloads/Open-WebUI.AppImage
OPEN_WEBUI_APPIMAGE=

# Ollama must be running locally with: ollama serve
OLLAMA_BASE_URLS=http://127.0.0.1:11434

# ChromaDB server settings
VECTOR_DB=chroma
CHROMA_HTTP_HOST=127.0.0.1
CHROMA_HTTP_PORT=8000
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database

# Model selected in Open WebUI for normal chat.
# This must be chat-capable.
CHAT_MODEL=llama3.2:3b

# Use Ollama to generate RAG document/query embeddings.
# This model is embedding-only; do not select it as the chat model.
RAG_EMBEDDING_ENGINE=ollama
RAG_EMBEDDING_MODEL=nomic-embed-text

# Local persistence/log paths
CHROMA_PATH=./data/chromadb
DATA_DIR=./data/open-webui
LOG_DIR=./logs
